ng">&quot;&quot;</span>;</span><br><span class="line">    &#125;</span><br><span class="line">    </span><br><span class="line">    <span class="type">int</span> <span class="title function_">nextInt</span><span class="params">()</span>&#123;</span><br><span class="line">        <span class="keyword">return</span> Integer.parseInt(nextStr());</span><br><span class="line">    &#125;</span><br><span class="line">    </span><br><span class="line">    Double <span class="title function_">nextDouble</span><span class="params">()</span>&#123;</span><br><span class="line">        <span class="keyword">return</span> Double.parseDouble(nextStr());</span><br><span class="line">        </span><br><span class="line">    &#125;</span><br><span class="line">    </span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"></span><br></pre></td></tr></table></figure>



